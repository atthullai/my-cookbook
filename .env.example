# Add this to `.env.local` locally and to your Vercel project settings in production.
# DeepL Free keys usually use the free endpoint automatically.
DEEPL_API_KEY=your_deepl_api_key_here

# Optional: override the endpoint manually if needed.
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Nutrition calculation via Edamam Nutrition Analysis API.
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_app_key_here
